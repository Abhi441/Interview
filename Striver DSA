using System;
using System.Linq; // Added this to enable LINQ methods like Concat and OrderBy
					
public class Program
{
	public static void Main()
	{
		int[] arr1 = {3, 5, 4};
		int[] arr2 = {6, 2, 5};

		// Combines both arrays and sorts them in ascending order
		var result = arr1.Concat(arr2).OrderBy(x => x);

		Console.WriteLine(string.Join(", ", result));
	}
}


