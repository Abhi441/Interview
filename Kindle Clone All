    public static string ReverseString(string str)
  {
    char[] ch = str.ToCharArray();
    int left = 0;
    int right = str.Length - 1 ;
  while(right > left)
  {
      if(!Char.IsLetter(ch[left]))
      {
          left++;
      }
     else if(!Char.IsLetter(ch[right]))
      {
          right--;
      }
      else
      {
      char temp = ch[left];
      ch[left] = ch[right];
      ch[right] = temp;
      left++;
      right--;
  }
  }
  return new string(ch);
}
