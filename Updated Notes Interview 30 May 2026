        string method = Console.ReadLine();

        Console.WriteLine("Enter amount:");
        decimal amount = Convert.ToDecimal(Console.ReadLine());

        IPayment payment = PaymentFactory.GetPayment(method);
        payment.Pay(amount);

        Console.ReadKey();
    }
