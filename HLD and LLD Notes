9. Default Winning Strategy

public class DefaultWinningStrategy
    : IWinningStrategy
{
    public bool HasWon(
        Board board,
        Symbol symbol)
    {
        int size =
            board.Size;

        for(int i=0;i<size;i++)
        {
            bool row=true;

            for(int j=0;j<size;j++)
            {
                if(board
                    .GetCell(i,j)
                    .Symbol
                    != symbol)
                {
                    row=false;

                    break;
                }
            }

            if(row)
                return true;
        }

        for(int j=0;j<size;j++)
        {
            bool col=true;

            for(int i=0;i<size;i++)
            {
                if(board
                    .GetCell(i,j)
                    .Symbol
                    != symbol)
                {
                    col=false;

                    break;
                }
            }

            if(col)
                return true;
        }

        bool diag=true;

        for(int i=0;i<size;i++)
        {
            if(
                board
                .GetCell(i,i)
                .Symbol
                != symbol)
            {
                diag=false;
            }
        }

        if(diag)
            return true;

        diag=true;

        for(int i=0;i<size;i++)
        {
            if(
                board
                .GetCell(
                    i,
                    size-i-1)
                .Symbol
                != symbol)
            {
                diag=false;
            }
        }

        return diag;
    }
}


