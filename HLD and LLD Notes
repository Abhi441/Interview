7. Board Class

Core logic.

public class Board
{
    private readonly Cell[,] _cells;

    public int Size { get; }

    public Board(int size)
    {
        Size = size;

        _cells =
            new Cell[size, size];

        Initialize();
    }

    private void Initialize()
    {
        for(int i=0;i<Size;i++)
        {
            for(int j=0;j<Size;j++)
            {
                _cells[i,j]=
                    new Cell();
            }
        }
    }

    public bool PlaceMove(
        int row,
        int col,
        Symbol symbol)
    {
        if(row<0 ||
           row>=Size ||
           col<0 ||
           col>=Size)
            return false;

        if(!_cells[row,col]
                .IsEmpty())
            return false;

        _cells[row,col]
             .Mark(symbol);

        return true;
    }

    public bool IsFull()
    {
        for(int i=0;i<Size;i++)
        {
            for(int j=0;j<Size;j++)
            {
                if(
                    _cells[i,j]
                    .IsEmpty())
                    return false;
            }
        }

        return true;
    }

    public Cell GetCell(
        int row,
        int col)
    {
        return _cells[row,col];
    }

    public void Print()
    {
        for(int i=0;i<Size;i++)
        {
            for(int j=0;j<Size;j++)
            {
                Console.Write(
                _cells[i,j]
                .Symbol?.ToString()
                ?? "-");

                Console.Write(" ");
            }

            Console.WriteLine();
        }
    }
}


