public class Game
{
    private readonly Board _board;

    private readonly Player[] _players;

    private readonly
        IWinningStrategy
        _winningStrategy;

    private int turn;

    public Game(
        int size,
        Player p1,
        Player p2)
    {
        _board =
            new Board(size);

        _players =
            new[]
            {
                p1,
                p2
            };

        _winningStrategy =
            new DefaultWinningStrategy();
    }

    public void Play(
        int row,
        int col)
    {
        var player =
            _players[turn];

        bool placed =
            _board
            .PlaceMove(
                row,
                col,
                player.Symbol);

        if(!placed)
        {
            Console.WriteLine(
                "Invalid Move");

            return;
        }

        _board.Print();

        if(
            _winningStrategy
            .HasWon(
                _board,
                player.Symbol))
        {
            Console.WriteLine(
                $"{player.Name} Wins");

            return;
        }

        if(
            _board.IsFull())
        {
            Console.WriteLine(
                "Draw");

            return;
        }

        turn =
            (turn+1)%2;
    }
}


